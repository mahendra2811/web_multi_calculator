{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "mcpServers": {
    "code-review-graph": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@anthropic-ai/code-review-graph"]
    }
  },
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Bash(npm run *)",
      "Bash(npx tsc *)",
      "Bash(npx eslint *)",
      "Bash(npx prettier *)",
      "Bash(npx vitest *)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)"
    ]
  }
}
